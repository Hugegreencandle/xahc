# x402-xahau facilitator — environment template (PLACEHOLDERS ONLY; no real secrets).
# Copy to .env (gitignored) and fill in. Every var below is read by server.mjs.

# ---- Core ----
# HTTP listen port (default 4021).
PORT=4021

# Xahau WS endpoint. REQUIRED for /settle. If unset, /settle is DISABLED and the
# facilitator runs offline-only (/verify, signature checks). Must be ws:// or wss://.
# Xahau rippled speaks WS api_version 1 (the facilitator's settle client pins v1).
#   mainnet example:  wss://xahau.network
#   testnet example:  wss://xahau-test.net
XAHAU_WSS=wss://xahau.network

# Network selection. Set the explicit id, OR set XAHAU_NETWORK by name; if you set
# both they must agree (boot fails otherwise). mainnet=21337, testnet=21338.
XAHAU_NETWORK_ID=21337
# XAHAU_NETWORK=xahau          # alternative to the numeric id: "xahau" | "xahau-testnet"

# Shared secret guarding /settle, /metrics, and the VERBOSE form of /health.
# REQUIRED for production. Empty = reference/open mode (do not ship empty).
X402_SHARED_SECRET=change-me-to-a-long-random-string

# ---- Shared/durable store (optional but required for multi-instance) ----
# Set to a redis:// or rediss:// URL to use the SHARED, DURABLE replay store + limiter
# (server.mjs lazy-loads ioredis). If set but ioredis is missing, boot FAILS FAST.
# Redis MUST use a non-evicting maxmemory policy (noeviction or volatile-*).
# X402_REDIS_URL=redis://redis:6379

# ---- Replay store tuning (optional; sane defaults) ----
# X402_REPLAY_TTL_MS=3600000       # binding TTL fallback (1h)
# X402_REPLAY_MAX=100000           # hard cap on live replay bindings (fail-closed when full)
# X402_LEDGER_CLOSE_MS=4000        # assumed ledger close interval (~4s)
# X402_REPLAY_MARGIN_MS=300000     # expiry slack added to a tx's validity window (5m)

# ---- xrpl client resilience (optional) ----
# X402_CONNECT_TIMEOUT_MS=8000     # bounded connect timeout
# X402_CONNECT_ATTEMPTS=3          # connect attempts before failing closed
# X402_CONNECT_BACKOFF_MS=500      # backoff between attempts

# ---- Rate limiting (optional) ----
# X402_RATE_MAX=20                 # token-bucket capacity per client window
# X402_RATE_WINDOW_MS=60000        # window length (1m)
# X402_TRUST_PROXY=0               # trusted proxy hops for X-Forwarded-For (0 = ignore XFF; XFF is spoofable)

# ---- HTTP server hardening (optional) ----
# X402_REQUEST_TIMEOUT_MS=15000    # max time a slow client may drip a full request
# X402_HEADERS_TIMEOUT_MS=10000    # max time to receive headers (slowloris guard)
# X402_MAX_CONNECTIONS=1024        # cap on concurrent sockets
# X402_SHUTDOWN_DRAIN_MS=10000     # graceful-shutdown drain budget for in-flight requests
